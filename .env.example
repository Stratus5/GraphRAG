# Copy to .env and fill in. Neo4j defaults match docker-compose.yml.
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password123

# --- LLM / embeddings gateway (Live mode + CLI; not needed for tests) ---------
# Option A — OpenAI / FC gateway:
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
#
# Option B — local Ollama (OpenAI-compatible); set Ollama model names in config.yaml:
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
