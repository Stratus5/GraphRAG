#!/usr/bin/env bash
#
# Guard: never let docs/ or CLAUDE.md reach a public/main remote.
#
# Blocks a push when EITHER is true and the pushed tip still tracks
# docs/ or CLAUDE.md:
#   A) the destination branch is `main` (on any remote), or
#   B) the destination remote is GitHub.
#
# The internal docs branch (internal -> origin/internal) is unaffected:
# its ref isn't `main` and its remote isn't GitHub, so docs are allowed there.
#
# Install with:  ./scripts/install-hooks.sh
# Bypass in a genuine emergency with:  git push --no-verify

remote_name="$1"
remote_url="$2"

PROTECTED_PATHS=(docs CLAUDE.md)
zero="0000000000000000000000000000000000000000"

is_github=0
case "$remote_url" in
  *github.com*|*github:*) is_github=1 ;;
esac

blocked=0
while read -r local_ref local_sha remote_ref remote_sha; do
  # Skip branch deletions (nothing being added).
  [ "$local_sha" = "$zero" ] && continue

  dest_is_main=0
  case "$remote_ref" in
    refs/heads/main) dest_is_main=1 ;;
  esac

  # Only guard pushes to `main` (any remote) or anything going to GitHub.
  if [ "$dest_is_main" -eq 0 ] && [ "$is_github" -eq 0 ]; then
    continue
  fi

  hits="$(git ls-tree -r --name-only "$local_sha" -- "${PROTECTED_PATHS[@]}" 2>/dev/null)"
  if [ -n "$hits" ]; then
    if [ "$blocked" -eq 0 ]; then
      echo "" >&2
      echo "BLOCKED by pre-push hook: in-house files must not reach this destination." >&2
      echo "  remote : $remote_name ($remote_url)" >&2
    fi
    echo "  ref    : ${remote_ref:-<new>}  contains:" >&2
    echo "$hits" | sed 's/^/             /' >&2
    blocked=1
  fi
done

if [ "$blocked" -ne 0 ]; then
  echo "" >&2
  echo "These live only on origin/internal (code.stratus5.com). Do NOT merge internal -> main." >&2
  echo "If this was an accidental merge, reset main before pushing." >&2
  echo "To override intentionally: git push --no-verify" >&2
  echo "" >&2
  exit 1
fi

exit 0
